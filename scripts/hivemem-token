#!/bin/bash
# hivemem-token -- token management CLI for the Java runtime.
# Talks to PostgreSQL directly via psql. Mirrors the Java DbTokenService semantics:
#   * plaintext is a 32-byte URL-safe random string
#   * token_hash is its SHA-256 hex
#   * role is one of admin|writer|reader|agent
#   * expires_at is interval-based (e.g. 90d)
set -euo pipefail

if [ -n "${HIVEMEM_DB_PASSWORD:-}" ]; then
    export PGPASSWORD="$HIVEMEM_DB_PASSWORD"
fi
DB_USER="${HIVEMEM_DB_USER:-hivemem}"
DB_NAME="${HIVEMEM_DB_NAME:-hivemem}"
# Parse host from JDBC URL if DB_HOST not set (jdbc:postgresql://host:port/db)
if [ -z "${HIVEMEM_DB_HOST:-}" ] && [ -n "${HIVEMEM_JDBC_URL:-}" ]; then
    HIVEMEM_DB_HOST=$(echo "$HIVEMEM_JDBC_URL" | sed 's|.*://||;s|:.*||;s|/.*||')
fi
DB_HOST="${HIVEMEM_DB_HOST:-localhost}"
PSQL=(psql -U "$DB_USER" -h "$DB_HOST" -d "$DB_NAME" -v ON_ERROR_STOP=1 -q -t -A)

usage() {
    cat >&2 <<'EOF'
Usage:
  hivemem-token create <name> --role <admin|writer|reader|agent> [--expires <Nd>]
                              [--read-realms a,b] [--write-realms a]
  hivemem-token list
  hivemem-token revoke <name>
  hivemem-token info <name>
  hivemem-token set-email <name> <email>   # Cloudflare Access identity for a human row
EOF
    exit 2
}

valid_role() {
    case "$1" in
        admin|writer|reader|agent) return 0 ;;
        *) return 1 ;;
    esac
}

# "a,b" -> '{a,b}'::text[] (lowercased, spaces->dashes); "" -> NULL
# Each element is validated against ^[a-z0-9-]+$ after normalization -- rejects
# anything else (e.g. quotes) to prevent SQL injection into the unquoted heredoc.
to_pg_array() {
    if [ -z "$1" ]; then
        echo "NULL"
        return
    fi
    local IFS=','
    local -a elems
    read -ra elems <<< "$1"
    local out=""
    local elem norm
    for elem in "${elems[@]}"; do
        norm=$(echo "$elem" | tr 'A-Z' 'a-z' | tr ' ' '-')
        if ! [[ "$norm" =~ ^[a-z0-9-]+$ ]]; then
            echo "Error: invalid realm '${norm}' — realms may contain only lowercase letters, digits, and dashes" >&2
            exit 1
        fi
        if [ -z "$out" ]; then
            out="$norm"
        else
            out="${out},${norm}"
        fi
    done
    echo "'{${out}}'::text[]"
}

cmd_create() {
    local name="${1:-}"; shift || true
    local role=""
    local expires=""
    local read_realms=""
    local write_realms=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --role) role="${2:-}"; shift 2 ;;
            --expires) expires="${2:-}"; shift 2 ;;
            --read-realms) read_realms="${2:-}"; shift 2 ;;
            --write-realms) write_realms="${2:-}"; shift 2 ;;
            *) usage ;;
        esac
    done
    [ -n "$name" ] || usage
    [ -n "$role" ] || usage
    valid_role "$role" || { echo "Error: role must be admin|writer|reader|agent" >&2; exit 1; }

    # 32-byte URL-safe plaintext (base64url, no padding) -- same shape as the Java service.
    local plaintext
    plaintext=$(openssl rand 32 | base64 | tr '+/' '-_' | tr -d '=\n')
    local token_hash
    token_hash=$(printf %s "$plaintext" | openssl dgst -sha256 | awk '{print $NF}')

    local expires_expr="NULL"
    if [ -n "$expires" ]; then
        local days="${expires%d}"
        case "$days" in
            ''|*[!0-9]*) echo "Error: --expires must look like 90d" >&2; exit 1 ;;
        esac
        expires_expr="now() + interval '${days} days'"
    fi

    local read_realms_expr write_realms_expr
    read_realms_expr=$(to_pg_array "$read_realms")
    write_realms_expr=$(to_pg_array "$write_realms")

    "${PSQL[@]}" -v "tok_hash=${token_hash}" -v "tok_name=${name}" -v "tok_role=${role}" <<SQL >/dev/null
INSERT INTO api_tokens (token_hash, name, role, expires_at, read_realms, write_realms)
VALUES (:'tok_hash', :'tok_name', :'tok_role', NULL, ${read_realms_expr}, ${write_realms_expr});
SQL
    if [ "$expires_expr" != "NULL" ]; then
        "${PSQL[@]}" -v "tok_name=${name}" <<SQL >/dev/null
UPDATE api_tokens SET expires_at = ${expires_expr} WHERE name = :'tok_name';
SQL
    fi

    cat <<EOF

============================================================
  Token created: ${name} (role: ${role})
  Read realms:  ${read_realms:-<unrestricted>}
  Write realms: ${write_realms:-<unrestricted>}
  API token: ${plaintext}
  Save this now -- it cannot be retrieved later.
============================================================
EOF
}

cmd_list() {
    "${PSQL[@]}" -F $'\t' <<'SQL' | awk -F'\t' '
BEGIN { printf "%-20s %-10s %-10s %-20s %-20s %-20s %-20s\n", "Name", "Role", "Status", "Created", "Expires", "ReadRealms", "WriteRealms";
        printf "%s\n", "------------------------------------------------------------------------------------------------------------------------" }
{
    name=$1; role=$2; status=$3; created=substr($4,1,10); expires=$5; read_realms=$6; write_realms=$7;
    if (expires == "" || expires == "\\N") expires="never"; else expires=substr(expires,1,10);
    if (read_realms == "" || read_realms == "\\N") read_realms="*";
    if (write_realms == "" || write_realms == "\\N") write_realms="*";
    printf "%-20s %-10s %-10s %-20s %-20s %-20s %-20s\n", name, role, status, created, expires, read_realms, write_realms
}'
SELECT
    name,
    role,
    CASE
        WHEN revoked_at IS NOT NULL THEN 'revoked'
        WHEN expires_at IS NOT NULL AND expires_at < now() THEN 'expired'
        ELSE 'active'
    END AS status,
    created_at::text,
    coalesce(expires_at::text, ''),
    coalesce(array_to_string(read_realms, ','), ''),
    coalesce(array_to_string(write_realms, ','), '')
FROM api_tokens
ORDER BY created_at;
SQL
}

cmd_revoke() {
    local name="${1:-}"
    [ -n "$name" ] || usage
    local updated
    updated=$("${PSQL[@]}" -v "tok_name=${name}" <<'SQL'
UPDATE api_tokens SET revoked_at = now()
WHERE name = :'tok_name' AND revoked_at IS NULL
RETURNING 1;
SQL
)
    if [ -z "$updated" ]; then
        echo "Error: Token '${name}' not found or already revoked" >&2
        exit 1
    fi
    echo "Token '${name}' revoked."
}

cmd_set_email() {
    [ "$#" -eq 2 ] || usage
    local name="${1:-}"
    local email_raw="${2:-}"
    [ -n "$name" ] && [ -n "$email_raw" ] || usage
    local email
    email=$(echo "$email_raw" | tr '[:upper:]' '[:lower:]')

    # Single transaction: the partial unique index on lower(email) covers every
    # non-revoked row, including expired ones that findByEmail can no longer see.
    # Without revoking those first, reassignment hits a unique violation and locks the
    # human out.
    #
    # WARNING: the previous row's bearer token dies with it. An api_tokens row is
    # dual-use -- it carries token_hash (Claude Code / CLI) AND email (the GUI). Moving
    # an email to a different row revokes the old row's bearer. Reissue it afterwards.
    local updated
    updated=$("${PSQL[@]}" -v "tok_name=${name}" -v "tok_email=${email}" <<'SQL'
BEGIN;
UPDATE api_tokens
   SET revoked_at = now()
 WHERE lower(email) = :'tok_email'
   AND revoked_at IS NULL
   AND name <> :'tok_name';
UPDATE api_tokens
   SET email = :'tok_email'
 WHERE name = :'tok_name'
   AND revoked_at IS NULL;
SELECT count(*) FROM api_tokens WHERE name = :'tok_name' AND lower(email) = :'tok_email';
COMMIT;
SQL
)
    if [ "$(echo "$updated" | tail -1)" != "1" ]; then
        echo "Error: no active token named '${name}'" >&2
        exit 1
    fi
    echo "ok: '${name}' now authenticates as ${email} via Cloudflare Access"
    echo "note: any other row that held this email was revoked -- reissue its bearer if in use" >&2
}

cmd_info() {
    local name="${1:-}"
    [ -n "$name" ] || usage
    local row
    row=$("${PSQL[@]}" -F $'\t' -v "tok_name=${name}" <<'SQL'
SELECT name,
       role,
       created_at::text,
       coalesce(expires_at::text, ''),
       coalesce(revoked_at::text, ''),
       coalesce(array_to_string(read_realms, ','), ''),
       coalesce(array_to_string(write_realms, ','), '')
FROM api_tokens
WHERE name = :'tok_name';
SQL
)
    if [ -z "$row" ]; then
        echo "Token '${name}' not found." >&2
        exit 1
    fi
    local IFS=$'\t'
    # shellcheck disable=SC2162
    read -r n r c e rv rr wr <<<"$row"
    [ -z "$e" ] && e="never"
    [ -z "$rv" ] && rv="no"
    [ -z "$rr" ] && rr="<unrestricted>"
    [ -z "$wr" ] && wr="<unrestricted>"
    printf "Name:         %s\nRole:         %s\nCreated:      %s\nExpires:      %s\nRevoked:      %s\nRead realms:  %s\nWrite realms: %s\n" \
        "$n" "$r" "$c" "$e" "$rv" "$rr" "$wr"
}

main() {
    [ "$#" -ge 1 ] || usage
    local cmd="$1"; shift
    case "$cmd" in
        create) cmd_create "$@" ;;
        list)   cmd_list "$@" ;;
        revoke) cmd_revoke "$@" ;;
        info)   cmd_info "$@" ;;
        set-email) cmd_set_email "$@" ;;
        -h|--help) usage ;;
        *) usage ;;
    esac
}

main "$@"
